projection;
strict ( 2 );
use draft;

define behavior for ZEGUI_C_AGENT_HEADER alias Header
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use action sendToLlm;

  use association _attachment { create; with draft; }
}

define behavior for zegui_c_attchmnts //alias <alias_name>
{

  use update;
  use delete;

  use association _header { with draft; }
}